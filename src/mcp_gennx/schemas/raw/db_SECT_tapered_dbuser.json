              "type": "boolean"
            },
            "USE_WARPING_EFFECT": {
              "description": "UseConsiderWarpingEffect",
              "type": "boolean"
            },
            "SHAPE": {
              "description": "Shape",
              "type": "string"
            },
            "TYPE": {
              "description": "Type",
              "type": "integer"
            },
            "SECT_I": {
              "type": "object",
              "properties": {
                "DB_NAME": {
                  "description": "DBName",
                  "type": "string"
                },
                "SECT_NAME": {
                  "description": "SectionName",
                  "type": "string"
                },
                "vSIZE": {
                  "description": "Size",
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                }
              }
            },
            "SECT_J": {
              "type": "object",
