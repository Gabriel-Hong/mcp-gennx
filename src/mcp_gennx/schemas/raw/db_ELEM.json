        },
        "NON_LEN": {
          "description": "NONLINIARLENGTH",
          "type": "number"
        },
        "CABLE": {
          "description": "CABLEOPTION",
          "type": "integer"
        },
        "C_RAT": {
          "description": "CABLELENGTHRATIO",
          "type": "number"
        },
        "WALL": {
          "description": "WALLID",
