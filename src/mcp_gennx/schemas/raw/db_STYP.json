        "Description": "Structure Type•\n3-D: 0•\nX-Z Plane: 1•\nY-Z Plane: 2•\nX-Y Plane: 3•\nConstraint RZ: 4",
        "Key": "STYP",
        "Value Type": "Integer",
        "Default": "System",
        "Required": "Optional"
      },
      {
        "No.": "2",
        "Description": "Mass Type•\nLumped Mass: 1•\nConsistent Mass: 2",
        "Key": "MASS",
        "Value Type": "Integer",
        "Default": "-",
        "Required": "Optional"
      },
      {
        "No.": "3",
        "Description": "Gravity Acceleration",
        "Key": "GRAV",
        "Value Type": "Number",
        "Default": "System",
        "Required": "Optional"
      },
      {
        "No.": "4",
        "Description": "Initial Temperature",
        "Key": "TEMP",
        "Value Type": "Number",
        "Default": "0",
        "Required": "Optional"
      },
      {
        "No.": "5",
        "Description": "Align Top of Beam Section",
        "Key": "bALIGNBEAM",
        "Value Type": "Boolean",
        "Default": "false",
        "Required": "Optional"
      },
      {
        "No.": "6",
        "Description": "Align the Top of the Slab (Plate)",
        "Key": "bALIGNSLAB",
        "Value Type": "Boolean",
        "Default": "false",
        "Required": "Optional"
      },
      {
