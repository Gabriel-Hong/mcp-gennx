      },
      {
        "No.": "9",
        "Description": "Convert Self-weight into Masses",
        "Key": "bSELFWEIGHT",
        "Value Type": "Boolean",
        "Default": "false",
        "Required": "Optional"
      },
      {
        "_condition": "When Convert Self-weight into Masses, \"bSELFWEIGHT\" is True"
      },
      {
        "No.": "10",
        "Description": "Structure Mass Type•\nConvert to X, Y, Z: 1•\nConvert to X, Y: 2•\nConvert to Z: 3",
