{
  "endpoint": "db/EIGV",
  "title": "Eigenvalue Analysis Control",
  "url": "https://support.midasuser.com/hc/en-us/articles/35989224565273-Eigenvalue-Analysis-Control",
  "input_uri": "{base url} + db/EIGV",
  "active_methods": [
    "POST",
    "GET",
    "PUT",
    "DELETE"
  ],
  "json_schema": {
    "EIGV": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "properties": {
        "TYPE": {
          "description": "Typeofanalysis",
          "type": "string"
        },
        "iFREQ": {
          "description": "EigenVectors,Numberoffrequencies",
          "type": "integer"
        },
        "iITER": {
          "description": "EigenVectors,Numberofiterations",
          "type": "integer"
        },
        "iDIM": {
          "description": "EigenVectors,Subspacedimension",
          "type": "integer"
        },
        "TOL": {
          "description": "EigenVectors,ConvergenceTolerance",
          "type": "number"
        },
        "bMINMAX": {
          "description": "EigenVectors,Frequencyrangeofinterest",
          "type": "boolean"
        },
        "FRMIN": {
          "description": "EigenVectors,Searchfrom",
          "type": "number"
        },
        "FRMAX": {
          "description": "EigenVectors,Searchto",
          "type": "number"
        },
        "bSTRUM": {
          "description": "EigenVectors,StrumSequencecheck",
          "type": "boolean"
        },
        "bINCNL": {
          "description": "RitzVectors,IncludeGL-linkforcevector",
          "type": "boolean"
        },
        "iGNUM": {
          "description": "RitzVectors,NumberofGL-linkforcevector",
          "type": "integer"
        },
        "vRITZ": {
          "description": "RitzVectors,List",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "KIND": {
                "description": "LoadCaseType",
                "type": "string"
              },
              "CASE": {
                "description": "LoadCaseNo.",
                "type": "string"
              },
              "GROUND": {
                "description": "Groundtype",
                "type": "string"
              },
              "iNOG": {
                "description": "Numberofgeneration",
                "type": "integer"
              }
            }
          }
        }
      }
    }
  },
  "examples": {
    "Eigen Vectors - Subspace Iteration": {
      "Assign": {
        "1": {
          "TYPE": "EIGEN",
          "iFREQ": 100,
          "iITER": 20,
          "iDIM": 1,
          "TOL": 1e-10,
          "bMINMAX": false,
          "FRMIN": 0,
          "FRMAX": 1600,
          "bSTRUM": false
        }
      }
    },
    "Eigen Vectors - Lanczos": {
      "Assign": {
        "1": {
          "TYPE": "LANCZOS",
          "iFREQ": 100,
          "iITER": 20,
          "iDIM": 1,
          "TOL": 1e-10,
          "bMINMAX": false,
          "FRMIN": 0,
          "FRMAX": 0,
          "bSTRUM": false
        }
      }
    },
    "Ritz Vectors": {
      "Assign": {
        "1": {
          "TYPE": "RITZ",
          "bINCNL": false,
          "iGNUM": 1,
          "vRITZ": [
            {
              "KIND": "GROUND",
              "GROUND": "ACCX",
              "iNOG": 30
            },
            {
              "KIND": "GROUND",
              "GROUND": "ACCY",
              "iNOG": 30
            },
            {
              "KIND": "GROUND",
              "GROUND": "ACCZ",
              "iNOG": 30
            }
          ]
        }
      }
    }
  },
  "tables": [
    [
      {
        "No.": "1",
        "Description": "Type of Analysis•\nSubspace Iteration: \"EIGEN\"•\nLanczos: \"LANCZOS\"•\nRitz Vectors: \"RITZ\"",
        "Key": "TYPE",
        "Value Type": "String",
        "Default": "-",
        "Required": "Required"
      },
      {
        "_condition": "Eigen Vectors - Subspace Iteration"
      },
      {
        "No.": "2",
        "Description": "Number of Frequencies",
        "Key": "iFREQ",
        "Value Type": "Integer",
        "Default": "-",
        "Required": "Required"
      },
      {
        "No.": "3",
        "Description": "Number of Iterations",
        "Key": "iITER",
        "Value Type": "Integer",
        "Default": "-",
        "Required": "Required"
      },
      {
        "No.": "4",
        "Description": "Subspace Dimension",
        "Key": "iDIM",
        "Value Type": "Integer",
        "Default": "0",
        "Required": "Optional"
      },
      {
        "No.": "5",
        "Description": "Convergence Tolerance",
        "Key": "TOL",
        "Value Type": "Number",
        "Default": "0",
        "Required": "Optional"
      },
      {
        "_condition": "Eigen Vectors - Lanczos"
      },
      {
        "No.": "2",
        "Description": "Number of Frequencies",
        "Key": "iFREQ",
        "Value Type": "Integer",
        "Default": "-",
        "Required": "Required"
      },
      {
        "No.": "3",
        "Description": "Frequency Range of Interest",
        "Key": "bMINMAX",
        "Value Type": "Boolean",
        "Default": "false",
        "Required": "Optional"
      },
      {
        "No.": "4",
        "Description": "Seach From [cps]•\nWhen the \"bMINMAX\" is true•\n\"FRMIN\" < \"FRMAX\"",
        "Key": "FRMIN",
        "Value Type": "Number",
        "Default": "-",
        "Required": "Required"
      },
      {
        "No.": "5",
        "Description": "Seach to [cps]•\nWhen the \"bMINMAX\" is true•\n\"FRMIN\" < \"FRMAX\"",
        "Key": "FRMAX",
        "Value Type": "Number",
        "Default": "-",
        "Required": "Required"
      },
      {
        "No.": "6",
        "Description": "Sturm Sequence Check",
        "Key": "bSTRUM",
        "Value Type": "Boolean",
        "Default": "false",
        "Required": "Optional"
      },
      {
        "_condition": "Ritz Vectors"
      },
      {
        "No.": "2",
        "Description": "Include GL-link Force Vectors",
        "Key": "bINCNL",
        "Value Type": "Boolean",
        "Default": "false",
        "Required": "Optional"
      },
      {
        "No.": "3",
        "Description": "Number of Generations for Each GL-link Force",
        "Key": "iGNUM",
        "Value Type": "Integer",
        "Default": "-",
        "Required": "Required"
      },
      {
        "No.": "4",
        "Description": "Load Cases•\nInsert the data as an object",
        "Key": "vRITZ",
        "Value Type": "Array[Object]",
        "Default": "-",
        "Required": "Required"
      },
      {
        "No.": "(1)",
        "Description": "Load Case Type•\nGround Acc.: \"GROUND\"•\nGeneral: \"CASE\"",
        "Key": "KIND",
        "Value Type": "String",
        "Default": "-",
        "Required": "Required"
      },
      {
        "No.": "(2)",
        "Description": "Load Case Name•\nGeneral: Defined Load Case Name•\nGround Acc. X: \"ACCX\"•\nGround Acc. Y: \"ACCY\"•\nGround Acc. Z: \"ACCZ\"",
        "Key": "CASE",
        "Value Type": "String",
        "Default": "-",
        "Required": "Required"
      },
      {
        "No.": "(3)",
        "Description": "Number of Generations",
        "Key": "iNOG",
        "Value Type": "Integer",
        "Default": "Blank",
        "Required": "Optional"
      }
    ]
  ],
  "menu_name": "Eigenvalue Analysis Control"
}