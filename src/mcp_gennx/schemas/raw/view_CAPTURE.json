            "HEIGHT": {
              "type": "integer"
            },
            "STAGE_NAME": {
              "type": "string"
            },
            "SET_MODE": {
              "type": "string"
            },
            "SET_HIDDEN": {
              "type": "boolean"
            },
            "ACTIVE": {
              "type": "object",
              "description": "Veiw/Active"
            },
            "ANGLE": {
              "type": "object",
              "description": "Veiw/Angle"
            },
            "DISPLAY": {
              "type": "object",
              "description": "Veiw/Display"
            },
            "RESULT_GRAPHIC": {
              "type": "object",
              "description": "Veiw/Result Graphic"
            }
          }
        }
      }
    }
  },
  "examples": {
    "Capture": {
      "Argument": {
        "SET_MODE": "post",
        "SET_HIDDEN": false,
        "EXPORT_PATH": "C:\\MIDAS\\CaptureTest\\image.jpg",
        "HEIGHT": 1000,
        "WIDTH": 1000,
        "ACTIVE": {
          "ACTIVE_MODE": "Active",
          "N_LIST": [
            104,
            125,
            151,
            153
          ],
          "E_LIST": [
            196,
            228,
            229,
            231,
            232,
            269,
            270,
            279,
            280,
            291,
            292,
            349,
            350
          ]
        },
        "ANGLE": {
          "HORIZONTAL": 45,
          "VERTICAL": 60
        },
        "DISPLAY": {
          "NODE": {
            "NODE": true,
            "NODE_NUMBER": true
          },
          "PERSPECTIVE": true,
          "ZOOM_LEVEL": 150,
          "BGCOLOR_TOP": {
            "R": 255,
            "G": 125,
            "B": 125
          }
        },
        "RESULT_GRAPHIC": {
          "CURRENT_MODE": "beam diagrams",
          "LOAD_CASE_COMB": {
            "TYPE": "ST",
            "NAME": "DL"
          },
          "COMPONENTS": {
            "PART": "total",
            "COMP": "Fx"
          },
          "DISPLAY_OPTIONS": {
            "FIDELITY": "Exact",
            "FILL": "line fill",
            "SCALE": 1.0
          },
          "TYPE_OF_DISPLAY": {
            "CONTOUR": {
              "OPT_CHECK": true
            },
            "DEFORM": {
              "OPT_CHECK": true
            },
            "LEGEND": {
              "OPT_CHECK": true
            },
            "VALUES": {
              "OPT_CHECK": true
            }
          },
          "OUTPUT_SECT_LOCATION": {
            "OPT_I": true,
            "OPT_CENTER_MID": true,
            "OPT_J": true
          }
        }
      }
    }
  },
