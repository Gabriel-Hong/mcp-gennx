  "url": "https://support.midasuser.com/hc/en-us/articles/35996023805337-Capture",
  "input_uri": "{base url} + view/CAPTURE",
  "active_methods": [
    "POST"
  ],
  "json_schema": {
    "CAPTURE": {
      "$schema": "http://json-schema.org/draft-07/schema#",
